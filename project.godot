; Engine configuration file.
; OpenFire — cross-platform coop/deathmatch FPS (Godot 4.6)

config_version=5

[application]

config/name="OpenFire"
config/description="Cross-platform coop & deathmatch FPS with bots and configurable missions."
config/version="0.2.18"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Game="*res://scripts/autoload/game.gd"
Net="*res://scripts/autoload/net.gd"
Missions="*res://scripts/autoload/missions.gd"
WeaponDB="*res://scripts/autoload/weapon_db.gd"
ItemDB="*res://scripts/autoload/item_db.gd"
Characters="*res://scripts/autoload/characters.gd"
NameGen="*res://scripts/autoload/name_gen.gd"
LLM="*res://scripts/autoload/llm.gd"
Story="*res://scripts/autoload/story.gd"
ComfyUI="*res://scripts/autoload/comfyui.gd"
Audio="*res://scripts/autoload/audio.gd"
Music="*res://scripts/autoload/music.gd"
Settings="*res://scripts/autoload/settings.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[layer_names]

3d_physics/layer_1="world"
3d_physics/layer_2="players"
3d_physics/layer_3="bots"
3d_physics/layer_4="pickups"
3d_physics/layer_5="hitbox"

[navigation]

2d/default_edge_connection_margin=0.0

[physics]

3d/default_gravity=24.0

[rendering]

textures/canvas_textures/default_texture_filter=0
textures/vram_compression/import_etc2_astc=true
anti_aliasing/quality/msaa_3d=2
environment/defaults/default_environment="res://resources/default_env.tres"

[input_devices]

pointing/emulate_touch_from_mouse=false

[input]

