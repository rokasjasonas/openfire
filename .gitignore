# Godot 4+ specific ignores
.godot/
/android/
/.import/

# Local tooling (portable engine binary + raw asset downloads)
.tools/
.assets_src/

# Raw Kenney audio packs (300+ files) — only the curated subset in assets/audio/
# is used and committed. Re-download from kenney.nl if you want the full packs.
assets/kenney/audio/

# NobodyWho GDExtension binaries (65 MB+ each) — re-extract from the release
# zip into addons/nobodywho/. The .gdextension manifest + icon stay tracked.
addons/nobodywho/*.so
addons/nobodywho/*.dll
addons/nobodywho/*.dylib
addons/nobodywho/*.pdb

# Exported builds
/build/
/dist/
*.exe
*.dmg
*.x86_64
*.app/
*.pck
*.zip

# OS / editor cruft
.DS_Store
Thumbs.db
*~
*.swp
.vscode/
.idea/

# Adventure character saves (live next to the executable)
characters/

# ComfyUI checkpoints (multi-GB, auto-downloaded next to the binary — never committed)
*.safetensors
*.safetensors.part
/comfyui/
